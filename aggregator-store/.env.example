# Aggregator Store - Environment Configuration
# Копируйте этот файл в .env и заполните реальными значениями

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=aggregator_store
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Формат URL для SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password@db:5432/aggregator_store

# =============================================================================
# Redis (кэширование, сессии)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# JWT Authentication
# =============================================================================
# Генерируйте с помощью: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Aggregator Store
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# CORS origins (через запятую для production)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Email (для уведомлений - опционально)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@aggregator.store

# =============================================================================
# API Keys (для реальных маркетплейсов - опционально)
# =============================================================================
ALIEXPRESS_API_KEY=
AMAZON_API_KEY=
OZON_API_KEY=
WILDBERRIES_API_KEY=
YANDEX_MARKET_API_KEY=

# =============================================================================
# ML Service
# =============================================================================
ML_SERVICE_URL=http://ml-service:8001
ENABLE_RECOMMENDATIONS=true

# =============================================================================
# Pagination Defaults
# =============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
